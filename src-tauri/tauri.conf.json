{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Annotate",
  "version": "0.1.0",
  "identifier": "com.annotate.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Annotate",
        "width": 520,
        "height": 580,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true
      },
      {
        "label": "throbber",
        "url": "throbber.html",
        "width": 72,
        "height": 32,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https://api.fontshare.com; font-src https://api.fontshare.com; connect-src https://api.groq.com https://api.fontshare.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
